model Branch {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  requestId String?

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  users        User[]
  departments  Department[]
  crmLeads     CrmLead[]
  salesTargets SalesTarget[]
  crmAccounts  CrmAccount[]
  crmContacts  CrmContact[]
  crmQuotes    CrmQuote[]
  crmForecastSnapshots CrmForecastSnapshot[]
  crmRoutingRules CrmRoutingRule[]
  financeAccounts FinanceAccount[]
  financeBankAccounts FinanceBankAccount[]
  financeCostCenters FinanceCostCenter[]
  financeCategories FinanceCategory[]
  financePayables FinancePayable[]
  financeReceivables FinanceReceivable[]
  financeTransactions FinanceTransaction[]
  financeApprovalPolicies FinanceApprovalPolicy[]
  financeApprovalRequests FinanceApprovalRequest[]
  financeClosePeriods FinanceClosePeriod[]
  financeBudgetPlans FinanceBudgetPlan[]
  financeBudgetLines FinanceBudgetLine[]
  financeForecastSnapshots FinanceForecastSnapshot[]

  @@unique([companyId, name])
  @@index([companyId])
  @@index([companyId, createdAt])
}

model Department {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  requestId String?

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  users        User[]
  crmLeads     CrmLead[]
  salesTargets SalesTarget[]
  crmAccounts  CrmAccount[]
  crmContacts  CrmContact[]
  crmQuotes    CrmQuote[]
  crmForecastSnapshots CrmForecastSnapshot[]
  crmRoutingRules CrmRoutingRule[]
  financeAccounts FinanceAccount[]
  financeCostCenters FinanceCostCenter[]
  financeCategories FinanceCategory[]
  financePayables FinancePayable[]
  financeReceivables FinanceReceivable[]
  financeTransactions FinanceTransaction[]
  financeApprovalPolicies FinanceApprovalPolicy[]
  financeApprovalRequests FinanceApprovalRequest[]
  financeClosePeriods FinanceClosePeriod[]
  financeBudgetPlans FinanceBudgetPlan[]
  financeBudgetLines FinanceBudgetLine[]
  financeForecastSnapshots FinanceForecastSnapshot[]

  @@unique([branchId, name])
  @@index([companyId])
  @@index([branchId])
  @@index([companyId, branchId])
  @@index([companyId, createdAt])
}

model User {
  id        String   @id @default(cuid())
  email     String
  name      String
  password  String
  role      Role     @default(ADMIN)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  refreshTokenHash String?
  refreshTokenId   String?
  tokenVersion     Int     @default(1)

  sessions             Session[]
  auditLogs            AuditLog[]
  userPermissions      UserPermission[]
  ownedCrmLeads        CrmLead[]     @relation("CrmLeadOwner")
  ownedCrmAccounts     CrmAccount[]  @relation("CrmAccountOwner")
  ownedCrmContacts     CrmContact[]  @relation("CrmContactOwner")
  crmLeadActivities    CrmLeadActivity[]
  assignedCrmLeadTasks CrmLeadTask[] @relation("CrmLeadTaskAssignedUser")
  crmSavedViews        CrmSavedView[]
  salesTargets         SalesTarget[]
  crmMailboxes         CrmMailbox[]
  crmChannelIntegrations CrmChannelIntegration[]
  crmEmailTemplates    CrmEmailTemplate[]
  crmSequences         CrmSequence[]
  crmQuotes            CrmQuote[]
  crmDocuments         CrmDocument[]
  crmRoutingExecutions CrmRoutingExecution[] @relation("CrmRoutingExecutionAssignedUser")
  crmConversationInsights CrmConversationInsight[] @relation("CrmConversationInsightAuthor")
  crmForecastSnapshots CrmForecastSnapshot[] @relation("CrmForecastSnapshotOwner")
  crmForecastAdjustments CrmForecastAdjustment[] @relation("CrmForecastAdjustmentAuthor")
  financeApprovalRequestsRequested FinanceApprovalRequest[] @relation("FinanceApprovalRequester")
  financeApprovalRequestsApproved FinanceApprovalRequest[] @relation("FinanceApprovalApprover")
  financeCloseChecklistItemsCompleted FinanceCloseChecklistItem[] @relation("FinanceCloseChecklistCompletedBy")
  financeBudgetPlansOwned FinanceBudgetPlan[] @relation("FinanceBudgetPlanOwner")
  financeReconciliationMatches FinanceReconciliationMatch[] @relation("FinanceReconciliationMatchedBy")

  @@unique([companyId, email])
  @@index([companyId])
  @@index([branchId])
  @@index([departmentId])
  @@index([companyId, role])
  @@index([companyId, isActive])
  @@index([companyId, createdAt])
}

model Session {
  id               String    @id @default(cuid())
  createdAt        DateTime  @default(now())
  lastUsedAt       DateTime  @default(now())
  revokedAt        DateTime?
  ip               String?
  userAgent        String?
  refreshTokenHash String
  refreshTokenId   String    @unique

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([companyId])
  @@index([createdAt])
  @@index([lastUsedAt])
  @@index([revokedAt])
  @@index([userId, revokedAt])
  @@index([userId, createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  requestId String?

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  method     String
  path       String
  statusCode Int
  ip         String?
  userAgent  String?
  durationMs Int

  bodyJson   Json?
  queryJson  Json?
  paramsJson Json?

  @@index([createdAt])
  @@index([companyId])
  @@index([userId])
  @@index([method, path])
  @@index([requestId])
  @@index([companyId, createdAt])
  @@index([companyId, userId, createdAt])
  @@index([companyId, requestId])
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique
  description String?
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]
  userPermissions UserPermission[]

  @@index([createdAt])
}

model RolePermission {
  id           String     @id @default(cuid())
  role         Role
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
  @@index([role])
  @@index([permissionId])
  @@index([role, permissionId])
}

model UserPermission {
  id String @id @default(cuid())

  companyId String
